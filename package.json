{
  "name": "@aimarket/argus",
  "version": "0.1.0",
  "description": "ARGUS-3 — the wallet-native, security-hardened reference agent for the AICOM economy. Runs fully autonomously; clips into the economy when a wallet is present.",
  "type": "module",
  "license": "MIT",
  "author": "AICOM (alexar76)",
  "homepage": "https://magic-ai-factory.com/argus/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexar76/argus.git"
  },
  "bugs": {
    "url": "https://github.com/alexar76/argus/issues"
  },
  "bin": {
    "argus": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "web",
    "argus.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "mcp",
    "mcp-security",
    "llm",
    "aicom",
    "aimarket",
    "agent-economy",
    "multi-provider",
    "telegram-bot",
    "base"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/post-quantum": "^0.6.1",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@aimarket/agent": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@aimarket/agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aimarket/agent": "^0.1.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
