# ARGUS environment — copy to .env and fill what you use.
# EVERYTHING here is optional. With nothing set, ARGUS still runs against a
# local model (Ollama) and stays fully autonomous. Secrets live here, never in
# argus.config.json (which is safe to commit per-project).

# ---- Providers (set the keys for whatever you actually use) -----------------
# Anthropic-native (recommended for the core loop: best tool-use + cache_control)
ANTHROPIC_API_KEY=

# Any OpenAI-compatible endpoint (OpenAI, DeepSeek, Qwen/DashScope, Zhipu GLM,
# Moonshot/Kimi, MiniMax, Mistral, Groq, Together, OpenRouter, ...). Each entry
# in argus.config.json names an env var for its key; the defaults are below.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=

# Local model servers (no API key needed) — both are OpenAI-compatible:
#   Ollama   → http://127.0.0.1:11434/v1   (default below)
#   LM Studio→ http://127.0.0.1:1234/v1     (start its local server)
# argus.config.json already lists both as providers "ollama" and "lmstudio".
ARGUS_LOCAL_BASE_URL=http://127.0.0.1:11434/v1

# ---- Crypto / economy (OPT-IN — *** OFF BY DEFAULT ***) --------------------
# MASTER CRYPTO SWITCH. A real blockchain is NOT required to run ARGUS. Leave this
# unset (or 0) and ARGUS runs with NO wallet, NO chain, NO payments — just a local
# agent with WARDEN security + FREE off-chain oracle reads. Set to 1 (AND a wallet
# below) to enable the on-chain economy: wallet, lottery, ACEX, paid hub invokes,
# on-chain settlement.
ARGUS_CRYPTO_ENABLED=
# --- Wallet secret: pick ONE of the two ways below (used only when crypto is on) ---
# RECOMMENDED — the encrypted vault. Run `argus keystore create` once; the seed/key
# are stored AES-256-GCM encrypted at ~/.argus/keystore.json (never plaintext). At
# runtime set this passphrase (env / secret manager) to unlock the wallet. Without
# it the vault stays LOCKED and the economy simply stays off (fail-safe).
ARGUS_KEYSTORE_PASSPHRASE=
# DEV/LEGACY fallback — a 0x-prefixed secp256k1 private key in plaintext. Only used
# if there is no keystore. Prefer the vault above. (ARGUS_WALLET_MNEMONIC is read
# only by `argus keystore create` for non-interactive server migration, then drop it.)
ARGUS_WALLET_KEY=

# AICOM hub + service endpoints (defaults target the public ecosystem).
ARGUS_HUB_URL=https://magic-ai-factory.com
ARGUS_MESH_URL=https://magic-ai-factory.com
ARGUS_ORACLE_FAMILY_URL=https://magic-ai-factory.com

# ---- Telegram (OPT-IN) -----------------------------------------------------
# Bot token from @BotFather. With this set, `argus telegram` runs the bot.
ARGUS_TELEGRAM_TOKEN=
# Owner lock: only this Telegram user id may command the bot. Leave BLANK to use
# trust-on-first-use — the first user to /start claims the bot, everyone else is
# rejected. Owner gating is baked in and cannot be disabled.
ARGUS_TELEGRAM_OWNER_ID=

# ---- HTTP channel (used by `argus serve` / Docker) -------------------------
# Port for GET /health (open — the Alien Monitor node-visibility hook) and the
# token-gated POST /ask. Default 8787.
ARGUS_HTTP_PORT=8787
# Bearer token required for POST /ask. Leave BLANK to disable /ask (health stays
# open). Generate one, e.g.: openssl rand -hex 24
ARGUS_HTTP_TOKEN=

# ---- WARDEN threat intelligence (OPT-IN) -----------------------------------
# URL of a signed threat-intel feed; blank disables network threat updates
# (static rules + reputation still work).
ARGUS_THREAT_FEED_URL=
